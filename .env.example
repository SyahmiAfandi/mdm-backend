# Runtime
PORT=8080

# Supabase (use a server-side secret/service role key)
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_KEY=

# Firebase Admin
# Option A: set JSON content directly
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: mount a json file and point to it
# FIREBASE_SERVICE_ACCOUNT_PATH=/app/credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# Platform hint (optional)
# RENDER=false

